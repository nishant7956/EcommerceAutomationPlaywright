{
  // ─── OrangeHRM target app ────────────────────────────────────────────────
  "BaseUrl": "https://opensource-demo.orangehrmlive.com/web/index.php",

  // ─── User credentials dictionary ─────────────────────────────────────────
  //  Add as many roles as you need.  Tests reference these by role key so
  //  you change credentials once here rather than in every test.
  "Users": {
    "Admin": {
      "Username": "Admin",
      "Password": "admin123"
    },
    "Employee": {
      "Username": "Paul.T",
      "Password": "Tester@123"
    }
  },

  // ─── Browser / execution ─────────────────────────────────────────────────
  "Browser": "Chromium",
  "Headless": false,
  "SlowMotionMs": 0,
  "ViewportWidth": 1920,
  "ViewportHeight": 1080,

  // ─── Timeouts (milliseconds) ──────────────────────────────────────────────
  "DefaultTimeoutMs": 30000,
  "NavigationTimeoutMs": 60000,
  "RetryCount": 1,

  // ─── Parallelism ─────────────────────────────────────────────────────────
  //  Set this to 1 while building; raise once the framework is proven stable.
  //  NUnit reads this via [assembly: LevelOfParallelism(n)] driven from code.
  "ParallelWorkers": 1,

  // ─── Tracing / artifact capture ──────────────────────────────────────────
  //  TraceMode values: Always | OnFailure | Never
  "TraceMode": "OnFailure",
  "ArtifactsDirectory": "TestResults",

  // ─── API testing (Playwright IAPIRequestContext) ──────────────────────────
  "ApiBaseUrl": "https://opensource-demo.orangehrmlive.com/web/index.php/api/v2"
}
